{
  "name": "kiem_tra_domen",
  "version": "1.0.0",
  "description": "Empty project template pre-configured with ClaudeKit (agents, hooks, rules, skills, scripts).",
  "main": "functions/_worker.ts",
  "scripts": {
    "dev": "wrangler pages dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler pages deploy public",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "forceExit": true,
    "detectOpenHandles": true,
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ],
      "^.+\\.m?js$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json",
          "useESM": false
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(whoiser|axios)/)"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "hono": "^4.12.10",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.1",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "wrangler": "^4.80.0"
  }
}
