<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DomainSoft — Kiểm tra Tên miền</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Header -->
  <header class="site-header">
    <a href="/" class="logo">
      <span class="logo-icon material-symbols-outlined">dns</span>
      <span class="logo-text">DomainSoft</span>
    </a>
    <div class="auth-area">
      <% if (user) { %>
        <div class="user-info">
          <% if (user.photo) { %>
            <img src="<%= user.photo %>" alt="avatar" class="user-avatar">
          <% } %>
          <span class="user-name"><%= user.name %></span>
        </div>
        <a href="/auth/logout" class="auth-logout-link">Đăng xuất</a>
      <% } else { %>
        <a href="/auth/google" class="auth-btn neumorphic-raised">
          <svg class="google-icon" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615Z" fill="#4285F4"/>
            <path d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.258c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18Z" fill="#34A853"/>
            <path d="M3.964 10.707A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.707V4.961H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.039l3.007-2.332Z" fill="#FBBC05"/>
            <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.961L3.964 7.293C4.672 5.163 6.656 3.58 9 3.58Z" fill="#EA4335"/>
          </svg>
          Đăng nhập với Google
        </a>
      <% } %>
    </div>
  </header>

  <main class="main-content">

    <!-- Hero Section -->
    <section class="hero">
      <h1 class="hero-headline">Kiểm tra Tên miền</h1>
      <p class="hero-subtitle">Kiểm tra khả dụng và xem chi tiết đăng ký tên miền ngay lập tức</p>

      <!-- Search Bar -->
      <form id="search-form" class="search-form">
        <div class="search-bar neumorphic-inset">
          <span class="search-icon material-symbols-outlined">search</span>
          <input
            type="text"
            id="domain-input"
            class="search-input"
            placeholder="Nhập tên miền (vd: mysite.com)"
            autocomplete="off"
            autofocus
          >
          <button type="submit" id="search-btn" class="search-btn neumorphic-raised">
            Kiểm tra
          </button>
        </div>
      </form>

      <!-- Popular TLD Chips -->
      <div class="tld-chips">
        <span class="tld-label">Phổ biến:</span>
        <button type="button" class="tld-chip neumorphic-raised" data-tld=".com">.com</button>
        <button type="button" class="tld-chip neumorphic-raised" data-tld=".vn">.vn</button>
        <button type="button" class="tld-chip neumorphic-raised" data-tld=".net">.net</button>
        <button type="button" class="tld-chip neumorphic-raised" data-tld=".org">.org</button>
      </div>
    </section>

    <!-- Search History (localStorage) -->
    <div id="history" class="history-section hidden">
      <div class="history-header">
        <h3>🕐 Lịch sử Tìm kiếm</h3>
        <button type="button" id="clear-history" class="clear-history-btn">Xóa</button>
      </div>
      <div id="history-list" class="history-list"></div>
    </div>

    <!-- Loading State -->
    <div id="loading" class="loading-state hidden">
      <div class="spinner-wrap neumorphic-raised">
        <div class="spinner"></div>
      </div>
      <p class="loading-text">Đang kiểm tra tên miền...</p>
    </div>

    <!-- Error State -->
    <div id="error" class="error-box hidden">
      <span class="material-symbols-outlined error-icon">error</span>
      <span id="error-message"></span>
    </div>

    <!-- Results Section -->
    <div id="results" class="results-section hidden">

      <!-- Availability Card -->
      <div id="availability" class="availability-card neumorphic-raised"></div>

      <!-- Registration Details Panel (for taken domains) -->
      <div id="details" class="details-panel hidden">
        <h2 class="panel-title">
          <span class="material-symbols-outlined">assignment</span>
          Chi tiết Đăng ký
        </h2>
        <div class="details-grid" id="details-grid"></div>
      </div>

      <!-- Pricing Reference Card -->
      <div id="pricing" class="pricing-card hidden">
        <h2 class="panel-title">
          <span style="font-size:1.2rem">💰</span>
          Giá Tham khảo
        </h2>
        <div id="pricing-table-wrap"></div>
        <p class="pricing-disclaimer">
          * Giá tham khảo từ Cloudflare Registrar (giá gốc, tính theo năm).
          Giá thực tế tại các nhà đăng ký khác có thể cao hơn.
        </p>
      </div>

      <!-- Suggestions Section (two-column layout) -->
      <div id="suggestions" class="suggestions-section hidden">
        <h2 class="panel-title">
          <span class="material-symbols-outlined">lightbulb</span>
          Gợi ý Thay thế
        </h2>
        <div class="suggestions-columns">
          <!-- TLD Alternatives -->
          <div class="suggestions-col">
            <h3 class="col-heading">Phần mở rộng khác (TLDs)</h3>
            <div id="tld-suggestions" class="suggestions-list"></div>
          </div>
          <!-- Keyword Suggestions -->
          <div class="suggestions-col">
            <h3 class="col-heading">Gợi ý từ khóa</h3>
            <div id="keyword-suggestions" class="suggestions-list"></div>
          </div>
        </div>
      </div>

    </div>
    <!-- /#results -->

  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <p class="footer-brand">DomainSoft &copy; 2026</p>
    <nav class="footer-links">
      <a href="/privacy" class="footer-link">Chính sách Bảo mật</a>
      <a href="/terms" class="footer-link">Điều khoản Dịch vụ</a>
      <a href="/support" class="footer-link">Hỗ trợ</a>
    </nav>
    <p class="footer-note">Dữ liệu từ RDAP / WHOIS</p>
  </footer>

  <script src="/js/search.js" defer></script>
</body>
</html>
